# ==========================================
# CAPITAL PLUS AI AGENT - ENVIRONMENT CONFIG
# ==========================================
# Copia este archivo como .env y configura tus valores

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@host:port/database
POSTGRES_PORT=6543
POSTGRES_USER=capital_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=capital_plus_agent

# Pinecone Configuration
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=capitalplus-rag
PINECONE_ENVIRONMENT=us-east-1

# LM Studio Local Server
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=llama-3.2-3b-instruct

# OpenAI
OPENAI_API_KEY=sk-...

# Application Settings
NODE_ENV=development
UPLOAD_DIR=./tmp
MAX_FILE_SIZE=52428800
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Zoho CRM
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token
ZOHO_CRM_API_BASE_URL=https://www.zohoapis.com/crm/v2
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com/oauth/v2/token

# Hugging Face
HUGGINGFACE_API_KEY=hf_...

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Meta Ads & Zoho Integration
USE_REAL_ADAPTERS=True
META_ACCESS_TOKEN=your_meta_access_token
META_AD_ACCOUNT_ID=your_ad_account_id

# WhatsApp
WHATSAPP_ACCESS_TOKEN=your_whatsapp_token
WHATSAPP_VERIFY_TOKEN=your_verify_token

# Canva API (para generación de reportes)
CANVA_CLIENT_ID=your_canva_client_id
CANVA_CLIENT_SECRET=your_canva_client_secret

# Canva Template IDs por desarrollo
# Formato: CANVA_TEMPLATE_ID_{DESARROLLO_EN_MAYUSCULAS}
CANVA_TEMPLATE_ID_FUEGO=DAH...
CANVA_TEMPLATE_ID_AMURA=DAH...
CANVA_TEMPLATE_ID_PUNTO_TIERRA=DAH...

# Desarrollos válidos para reportes (separados por coma)
VALID_DESARROLLOS=FUEGO,AMURA,PUNTO_TIERRA
